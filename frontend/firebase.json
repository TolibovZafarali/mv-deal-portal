{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }],
    "redirects": [
      {
        "source": "**",
        "destination": "https://www.megna-realestate.com",
        "type": 301
      }
    ]
  }
}